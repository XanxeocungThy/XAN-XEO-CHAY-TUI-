<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>SĂN SALE CHÁY TÚI</title>
  <style>
    :root{
      --bg:#eef7ff;
      --card:#ffffff;
      --text:#29465b;
      --muted:#6e8290;
      --line:#d7e9f5;
      --blue:#7ec0ea;
      --blue2:#dff3ff;
      --purple:#efe8ff;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
      background:linear-gradient(180deg,#eef7ff,#fbfdff);
      color:var(--text);
    }
    .wrap{max-width:820px;margin:0 auto;padding:18px}
    .card{
      background:rgba(255,255,255,.95);
      border:1px solid var(--line);
      border-radius:28px;
      box-shadow:0 10px 30px rgba(80,130,170,.08);
      padding:18px;
    }
    .top{display:flex;gap:14px;align-items:center}
    .avatar{
      width:72px;height:72px;border-radius:18px;
      background:linear-gradient(135deg,#f6f0ff,#dff3ff);
      border:1px solid var(--line);
    }
    h1{
      margin:0;
      font-size:26px;
      line-height:1.1;
      font-weight:900;
      color:#27465a;
    }
    .desc{margin:6px 0 0;color:var(--muted);font-size:16px}
    .pills{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px}
    .pill{
      padding:10px 15px;
      border-radius:999px;
      background:#fff;
      border:1px solid #e5edf3;
      box-shadow:0 2px 10px rgba(0,0,0,.03);
      font-weight:700;
      color:#5d7687;
    }
    .pill.purple{background:var(--purple)}
    .btnrow{display:flex;gap:12px;flex-wrap:wrap;margin-top:14px}
    .btn{
      border:1px solid var(--line);
      background:#fff;
      color:#4f6e86;
      border-radius:22px;
      padding:14px 18px;
      font-weight:800;
      font-size:16px;
      cursor:pointer;
      flex:1;
      min-width:170px;
      text-decoration:none;
      display:inline-flex;
      align-items:center;
      justify-content:center;
    }
    .btn.primary{
      background:var(--blue);
      border-color:var(--blue);
      color:#fff;
    }
    .section{
      background:rgba(255,255,255,.95);
      border:1px solid var(--line);
      border-radius:28px;
      box-shadow:0 10px 30px rgba(80,130,170,.08);
      padding:18px;
      margin-top:18px;
    }
    .title{
      font-size:20px;
      font-weight:900;
      text-align:center;
      color:#8bbce4;
      letter-spacing:.4px;
      margin:4px 0 16px;
    }
    .inputrow{display:flex;gap:10px;flex-wrap:wrap}
    .inputwrap{flex:1;min-width:220px}
    input{
      width:100%;
      border:1px solid #cfdbe5;
      border-radius:18px;
      padding:14px 16px;
      font-size:16px;
      outline:none;
      background:#fff;
    }
    input:focus{
      border-color:#8dc9ef;
      box-shadow:0 0 0 4px rgba(126,192,234,.12);
    }
    .small{
      padding:14px 16px;
      border-radius:18px;
      border:1px solid var(--blue);
      background:#fff;
      color:#5a8dad;
font-weight:800;
      cursor:pointer;
    }
    .result{
      margin-top:14px;
      background:#f6fcff;
      border:1px solid #d9edf7;
      border-radius:18px;
      padding:14px;
      display:none;
    }
    .result code{
      display:block;
      white-space:pre-wrap;
      word-break:break-all;
      background:#fff;
      border:1px solid #e5eef5;
      border-radius:14px;
      padding:12px;
    }
    .grid{
      display:grid;
      grid-template-columns:1.2fr .8fr;
      gap:18px;
      align-items:center;
    }
    .big{font-size:30px;font-weight:900}
    .sub{color:#7b8794;font-weight:700;margin-top:4px}
    @media (max-width:720px){
      .grid{grid-template-columns:1fr}
      .btn{min-width:0}
      .top{align-items:flex-start}
      .avatar{width:64px;height:64px}
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <div class="top">
        <div class="avatar"></div>
        <div>
          <h1>🛍️ SĂN SALE CHÁY TÚI</h1>
          <p class="desc">Dán link Shopee vào, web tự ghép dấu hiệu Instagram và cho bạn copy ngay.</p>
          <div class="pills">
            <div class="pill">IG: blue_ne10</div>
            <div class="pill purple">ID Shopee: 17314740041</div>
          </div>
        </div>
      </div>
      <div class="btnrow">
        <a class="btn" href="https://s.shopee.vn/8V6derISfd" target="_blank" rel="noopener">Mở Shopee</a>
      </div>
    </div>

    <div class="section">
      <div class="title">DÁN LINK = IG</div>
      <div class="inputrow">
        <div class="inputwrap">
          <input id="link" placeholder="Dán link Shopee vào đây..." value="https://s.shopee.vn/8V6derISfd" />
        </div>
        <button class="small" onclick="convertLink()">Chuyển</button>
      </div>

      <div class="result" id="result">
        <strong>Link IG-ready:</strong>
        <code id="out"></code>
        <div class="btnrow" style="margin-top:12px">
          <button class="small" onclick="copyOut()">Copy link</button>
          <a class="btn" id="open" target="_blank" rel="noopener">Mở link</a>
        </div>
      </div>
    </div>

    <div class="section">
      <div class="grid">
        <div>
          <div class="big">02:00</div>
          <div class="sub">ĐÃ KẾT THÚC</div>
        </div>
        <div style="text-align:right">
          <div class="pill">3 khung giờ gần nhất</div>
        </div>
      </div>
    </div>
  </div>

  <script>
    function addIGParam(url){
      if(!url) return '';
      const sep = url.includes('?') ? '&' : '?';
      return url + sep + 'share_channel_code=3';
    }

    function convertLink(){
      const u = document.getElementById('link').value.trim();
      if(!u){
        alert('Vui lòng dán link Shopee');
        return;
      }
      const out = addIGParam(u);
      document.getElementById('out').textContent = out;
      document.getElementById('open').href = out;
document.getElementById('result').style.display = 'block';
    }

    async function copyOut(){
      const t = document.getElementById('out').textContent;
      if(!t) return;
      await navigator.clipboard.writeText(t);
      alert('Đã copy');
    }

    convertLink();
  </script>
</body>
</html>
